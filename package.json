{
    "name": "theme-tmnt",
    "version": "0.1.0",
    "displayName": "TMNT Theme",
    "homepage": "https://github.com/malm/tmnt-vs-code",
    "description": "A family of 5 VSCode color themes that blend the Dracula theme's structure and contrast rhythm with TMNT aesthetics.",
    "publisher": "tmnt-theme",
    "license": "MIT",
    "scripts": {
        "build": "node ./scripts/build.js",
        "lint": "node ./scripts/lint.js",
        "package": "vsce package -o ./bin/tmnt.vsix",
        "vsce-publish": "vsce publish"
    },
    "maintainers": [],
    "contributors": [
        "A fork of the Dracula Theme Official vscode extension modified for TMNT theme aesthetics"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/malm/tmnt-vs-code.git"
    },
    "bugs": {
        "url": "https://github.com/malm/tmnt-vs-code/issues"
    },
    "engines": {
        "vscode": "^1.13.0"
    },
    "categories": [
        "Themes"
    ],
    "keywords": [
        "tmnt",
        "dracula",
        "dark",
        "theme",
        "color-theme"
    ],
    "icon": "icon.png",
    "galleryBanner": {
        "color": "#3c4557",
        "theme": "dark"
    },
    "contributes": {
        "themes": [
            {
                "label": "TMNT (base)",
                "uiTheme": "vs-dark",
                "path": "./theme/tmnt.json"
            },
            {
                "label": "TMNT Leonardo",
                "uiTheme": "vs-dark",
                "path": "./theme/tmnt-leonardo.json"
            },
            {
                "label": "TMNT Raphael",
                "uiTheme": "vs-dark",
                "path": "./theme/tmnt-raphael.json"
            },
            {
                "label": "TMNT Michelangelo",
                "uiTheme": "vs-dark",
                "path": "./theme/tmnt-michelangelo.json"
            },
            {
                "label": "TMNT Donatello",
                "uiTheme": "vs-dark",
                "path": "./theme/tmnt-donatello.json"
            }
        ]
    },
    "devDependencies": {
        "js-yaml": "^4.1.1",
        "prettier": "^3.0.0",
        "tinycolor2": "^1.6.0",
        "vsce": "^2.15.0"
    }
}
